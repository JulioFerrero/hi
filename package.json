{
  "name": "web-builder",
  "private": true,
  "scripts": {
    "dev:web": "turbo dev --filter=@wb/web",
    "dev:editor": "turbo dev --filter=@wb/editor-app",
    "build:web": "turbo build --filter=@wb/web",
    "build:editor": "turbo build --filter=@wb/editor-app",
    "start:web": "turbo start --filter=@wb/web",
    "start:editor": "turbo start --filter=@wb/editor-app",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postgres",
    "db:generate": "cd packages/database && npx drizzle-kit generate",
    "db:migrate": "cd packages/database && npx drizzle-kit migrate",
    "db:push": "cd packages/database && npx drizzle-kit push",
    "db:studio": "cd packages/database && npx drizzle-kit studio",
    "db:seed": "cd packages/database && npx tsx src/seed.ts",
    "setup": "docker compose up -d && sleep 3 && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.10.0"
}
